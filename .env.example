# ─────────────────────────────────────────────────────────────────────────
# NexusBarrier — environment template (.env.example)   *** SAFE TO COMMIT ***
#
# Copy to `.env` and fill in real values for local development:
#     cp .env.example .env
# In production, set these as real platform/container environment variables
# (real env vars take precedence over any .env file).
#
# NO real secret belongs in this file. It documents variable NAMES only.
# ─────────────────────────────────────────────────────────────────────────

# Flask session / CSRF signing key. Must be stable across workers & restarts.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
NEXUSBARRIER_SECRET_KEY=replace-with-a-long-random-string

# JWT signing secret for auth tokens (HS256).
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-hex-string

# Field-level PII encryption key (Fernet / AES).
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key makes previously-encrypted PII unreadable.
# Rotation (comma-separated, new key first): NEW_FERNET_KEY,OLD_FERNET_KEY
NEXUSBARRIER_PII_KEY=replace-with-a-fernet-key

# Platform Super Admin bootstrap (first /platform admin, created on startup if
# the username does not already exist). There is intentionally NO code default.
PLATFORM_ADMIN_USERNAME=your_platform_admin_username
PLATFORM_ADMIN_PASSWORD=your_strong_admin_password

# Optional non-secret tuning — safe code defaults exist; uncomment to override.
# RESET_COOLDOWN_SECONDS=30
# PIPELINE_COOLDOWN_SECONDS=120
