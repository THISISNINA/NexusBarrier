# ─────────────────────────────────────────────────────────────────────────
# NexusBarrier — Python / Flask / SQLite .gitignore
# ─────────────────────────────────────────────────────────────────────────

# Secrets / environment — NEVER commit real secrets.
# Ignore every .env variant, but keep the public template tracked.
.env
.env.*
!.env.example

# Virtual environments
.venv/
venv/
env/
ENV/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# SQLite databases (local data — regenerable via the pipeline)
data/database/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# Logs
logs/
*.log

# Flask / build / packaging artifacts
instance/
.webassets-cache
build/
dist/
*.egg-info/

# IDE / editor
.idea/
.vscode/
*.swp

# OS-specific files
.DS_Store
Thumbs.db
